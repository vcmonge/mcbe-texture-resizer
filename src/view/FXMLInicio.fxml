<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--
    Main view of the Iron — Texture Resizer application.
    Contains:
    - Top bar with folder selector and controls
    - TabPane with tabs for Blocks, Items, Environment and Entity
    - Multi-selection and sorting controls
    - Bottom status bar
    
    @author vmonge
-->
<BorderPane xmlns:fx="http://javafx.com/fxml/1" 
            xmlns="http://javafx.com/javafx/8"
            fx:controller="controller.FXMLInicioController"
            styleClass="mainPane">
    
    <stylesheets>
        <URL value="@fxmlinicio.css" />
    </stylesheets>
    
    <!-- TOP BAR -->
    <top>
        <VBox styleClass="header-container">
            <!-- Title -->
            <HBox alignment="CENTER" styleClass="title-bar">
                <Label text="Texture Resizer | Minecraft Bedrock" styleClass="app-title"/>
            </HBox>
            
            <!-- Main controls -->
            <HBox alignment="CENTER_LEFT" spacing="15" styleClass="toolbar">
                <padding>
                    <Insets top="10" right="20" bottom="10" left="20"/>
                </padding>
                
                <!-- Folder selector -->
                <Label text="Root folder:"/>
                <TextField fx:id="txtRootPath" 
                           prefWidth="350" 
                           promptText="Select the resource pack folder..."
                           editable="false"/>
                <Button fx:id="btnSelectFolder" 
                        text="Browse..." 
                        onAction="#handleSelectFolder"
                        styleClass="btn-primary"/>
                
                <!-- Separator -->
                <Region HBox.hgrow="ALWAYS"/>
                
                <!-- Scale factor -->
                <Label text="Factor:"/>
                <ComboBox fx:id="cmbScaleFactor" prefWidth="70"/>
                
                <!-- Resize algorithm -->
                <Label text="Algorithm:"/>
                <ComboBox fx:id="cmbAlgorithm" prefWidth="160"/>
                
                <!-- Load button -->
                <Button fx:id="btnLoad" 
                        text="Load Textures" 
                        onAction="#handleLoadTextures"
                        styleClass="btn-success"
                        disable="true"/>
            </HBox>
            
            <!-- Secondary toolbar -->
            <HBox alignment="CENTER_LEFT" spacing="15" styleClass="toolbar-secondary">
                <padding>
                    <Insets top="8" right="20" bottom="8" left="20"/>
                </padding>
                
                <!-- Selection Mode -->
                <Label text="Selection:"/>
                <ToggleButton fx:id="btnSelectionMode" 
                              text="Enable Selection" 
                              onAction="#handleToggleSelectionMode"
                              styleClass="btn-toggle"/>
                
                <Button fx:id="btnProcessSelected" 
                        text="Process Selected (0)" 
                        onAction="#handleProcessSelected"
                        styleClass="btn-warning"
                        disable="true"
                        visible="false"
                        managed="false"/>
                
                <Button fx:id="btnSelectAll" 
                        text="Select All" 
                        onAction="#handleSelectAll"
                        styleClass="btn-secondary"
                        visible="false"
                        managed="false"/>
                
                <Button fx:id="btnDeselectAll" 
                        text="Deselect All" 
                        onAction="#handleDeselectAll"
                        styleClass="btn-secondary"
                        visible="false"
                        managed="false"/>
                
                <!-- Separator -->
                <Region HBox.hgrow="ALWAYS"/>
                
                <!-- Sorting -->
                <Label text="Sort by:"/>
                <ComboBox fx:id="cmbSortOrder" prefWidth="180"/>
                
            </HBox>
        </VBox>
    </top>
    
    <!-- MAIN CONTENT - TABPANE -->
    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" styleClass="texture-tabs">
            
            <!-- Blocks tab -->
            <!-- ScrollPane left empty in FXML; the controller
                 instantiates a CanvasTextureGrid and sets it as content. -->
            <Tab text="Blocks" closable="false">
                <ScrollPane fx:id="scrollBlocks" 
                           fitToWidth="true" 
                           styleClass="texture-scroll"/>
            </Tab>
            
            <!-- Items tab -->
            <Tab text="Items" closable="false">
                <ScrollPane fx:id="scrollItems" 
                           fitToWidth="true" 
                           styleClass="texture-scroll"/>
            </Tab>
            
            <!-- Environment tab -->
            <Tab text="Environment" closable="false">
                <ScrollPane fx:id="scrollEnvironment" 
                           fitToWidth="true" 
                           styleClass="texture-scroll"/>
            </Tab>
            
            <!-- Entity tab -->
            <Tab text="Entity" closable="false">
                <ScrollPane fx:id="scrollEntity" 
                           fitToWidth="true" 
                           styleClass="texture-scroll"/>
            </Tab>
            
        </TabPane>
    </center>
    
    <!-- BOTTOM STATUS BAR -->
    <bottom>
        <HBox styleClass="status-bar" spacing="20">
            <padding>
                <Insets top="8" right="20" bottom="8" left="20"/>
            </padding>
            
            <!-- Load info -->
            <Label fx:id="lblStatus" text="Ready"/>
            
            <!-- Separator -->
            <Region HBox.hgrow="ALWAYS"/>
            
            <!-- Counters -->
            <Label fx:id="lblBlocksCount" text="Blocks: 0"/>
            <Label fx:id="lblItemsCount" text="Items: 0"/>
            <Label fx:id="lblEnvironmentCount" text="Environment: 0"/>
            <Label fx:id="lblEntityCount" text="Entity: 0"/>
            
            <!-- Progress bar -->
            <ProgressBar fx:id="progressBar" prefWidth="200" visible="false"/>
        </HBox>
    </bottom>
    
</BorderPane>
